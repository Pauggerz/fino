SUPABASE_URL= your_real_key_here
SUPABASE_ANON_KEY= your_real_key_here
SUPABASE_DB_URL= your_real_key_here
SUPABASE_STORAGE_URL= your_real_key_here
VISION_API_KEY=your_real_key_here

RAILWAY_DB_URL=
RAILWAY_DB_PUBLIC_URL=

# ── Push notifications (server / EAS — not needed for the local mobile app) ──
# Service-role key used by the Supabase Edge Function dispatchers (server only).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Shared secret pg_cron sends as a Bearer token when invoking dispatchers.
# Store the same value in Supabase Vault as `edge_invoke_jwt` (see supabase/cron.sql).
EDGE_INVOKE_JWT=
# Optional: Expo access token for authenticated push sends + receipt polling.
EXPO_ACCESS_TOKEN=
# EAS secret name (set via `eas secret:create`) holding the Android
# google-services.json that expo-notifications consumes on build.
GOOGLE_SERVICES_JSON=