        {
          "iosShareExtensionName": "fino",
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          },
          "iosShareAppGroupIdentifier": "group.com.fino.app"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "286a6e23-4b2f-4147-84bf-c7be9bb910ae"
